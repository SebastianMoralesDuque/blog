---
import BaseLayout from '../layouts/BaseLayout.astro';

const socialLinks = [
  {
    href: 'https://www.linkedin.com/in/sebas-dev/',
    label: 'LinkedIn',
    description: 'Conectemos profesionalmente',
    icon: 'M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z',
  },
  {
    href: 'https://github.com/SebastianMoralesDuque',
    label: 'GitHub',
    description: 'Revisa mis proyectos',
    icon: 'M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12',
  },
  {
    href: 'https://portafolio.sebastianmorales.sbs/',
    label: 'Portafolio',
    description: 'Revisa mi trabajo',
    icon: 'M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z',
  },
];
---

<BaseLayout title="Sobre mí" description="Sebastian Morales — Desarrollador y analista de tecnología.">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 py-12 md:py-20">
    <!-- Hero Section -->
    <section class="mb-12 md:mb-16" data-animate>
      <div class="flex flex-col sm:flex-row gap-8 items-start">
        <!-- Avatar -->
        <div class="flex-shrink-0">
          <div class="relative group">
            <div class="w-28 h-28 md:w-36 md:h-36 rounded-2xl bg-gradient-to-br from-brand-500 to-fuchsia-500 flex items-center justify-center text-white text-4xl md:text-5xl font-bold shadow-xl shadow-brand-500/25 group-hover:shadow-brand-500/40 transition-all duration-300 group-hover:scale-[1.02]">
              SM
            </div>
            <div class="absolute inset-0 rounded-2xl bg-gradient-to-br from-brand-500 to-fuchsia-500 blur-2xl opacity-0 group-hover:opacity-30 transition-opacity duration-500"></div>
          </div>
        </div>

        <!-- Bio -->
        <div class="flex-1">
          <h1 class="text-3xl sm:text-4xl font-extrabold tracking-tight text-[rgb(var(--color-text))] mb-4 leading-tight">
            Sebastian
            <span class="gradient-text"> Morales</span>
          </h1>
          <p class="text-lg text-[rgb(var(--color-text-secondary))] leading-relaxed">
            Desarrollador Full Stack. Escribo sobre tecnología, poder y estructuras económicas.
          </p>
        </div>
      </div>
    </section>

    <!-- Divider -->
    <div class="h-px bg-gradient-to-r from-transparent via-[rgb(var(--color-brand)/0.3)] to-transparent mb-12 md:mb-16"></div>

    <!-- About Content -->
    <section class="mb-12 md:mb-16" data-animate>
      <div class="prose-custom">
        <p>
          Soy desarrollador de software con más de 10 años de experiencia. Construyo aplicaciones web modernas,
          pero mi interés real está en entender <strong>por qué</strong> construimos las cosas que construimos
          y <strong>para quién</strong> están diseñadas.
        </p>
        <p>
          Este blog es mi espacio para analizar la industria tecnológica sin filtros corporativos.
          Cada artículo busca ir más allá del hype y preguntarse quién gana, quién pierde,
          y qué estructuras económicas están en juego detrás de cada lanzamiento, adquisición o política de plataforma.
        </p>
        <p>
          Cuando no estoy programando o escribiendo, me encontrarás explorando herramientas de IA,
          contribuyendo a proyectos open source, o debatiendo sobre el futuro de la tecnología
          y su impacto real en la sociedad.
        </p>
      </div>
    </section>

    <!-- Contact Section -->
    <section data-animate>
      <div class="glass rounded-2xl p-8 md:p-10">
        <div class="text-center mb-8">
          <h2 class="text-xl font-bold text-[rgb(var(--color-text))] mb-2">Contacto</h2>
          <p class="text-sm text-[rgb(var(--color-text-muted))]">
            Siempre abierto a conversaciones interesantes.
          </p>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
          {socialLinks.map((link) => (
            <a
              href={link.href}
              target={link.href.startsWith('mailto') ? undefined : '_blank'}
              rel={link.href.startsWith('mailto') ? undefined : 'noopener noreferrer'}
              class="flex items-center gap-4 p-4 rounded-xl border border-[rgb(var(--color-border))] hover:border-[rgb(var(--color-brand)/0.3)] hover:bg-[rgb(var(--color-brand)/0.02)] hover-lift group transition-all duration-300"
            >
              <div class="flex-shrink-0 w-10 h-10 rounded-xl bg-gradient-to-br from-brand-100 to-fuchsia-100 dark:from-brand-900/50 dark:to-fuchsia-900/50 flex items-center justify-center text-brand-600 dark:text-brand-400 group-hover:from-brand-200 group-hover:to-fuchsia-200 dark:group-hover:from-brand-800/50 dark:group-hover:to-fuchsia-800/50 transition-all duration-300">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d={link.icon} />
                </svg>
              </div>
              <div>
                <div class="font-semibold text-sm text-[rgb(var(--color-text))] group-hover:text-[rgb(var(--color-brand))] transition-colors">
                  {link.label}
                </div>
                <div class="text-xs text-[rgb(var(--color-text-muted))]">
                  {link.description}
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  </div>
</BaseLayout>
