---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title="Inicio">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 py-12 md:py-20">
    <!-- Hero Section -->
    <section class="mb-16 md:mb-24" data-animate>
      <div class="relative">
        <!-- Decorative element -->
        <div class="absolute -top-8 -left-8 w-32 h-32 bg-gradient-to-br from-brand-400/20 to-fuchsia-400/20 dark:from-brand-400/10 dark:to-fuchsia-400/10 rounded-3xl blur-2xl"></div>

        <div class="relative">
          <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[rgb(var(--color-brand-surface))] border border-[rgb(var(--color-brand)/0.2)] mb-6">
            <span class="w-2 h-2 rounded-full bg-brand-500 animate-pulse"></span>
            <span class="text-sm font-medium text-[rgb(var(--color-brand))]">Actualizaciones diarias</span>
          </div>

          <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-extrabold tracking-tight text-[rgb(var(--color-text))] mb-6 leading-[1.05]">
            Crítica
            <span class="gradient-text"> Tecnológica</span>
          </h1>

          <p class="text-lg md:text-xl text-[rgb(var(--color-text-secondary))] max-w-2xl leading-relaxed mb-10">
            Análisis diario de tecnología desde la perspectiva del materialismo histórico.
            Relaciones de poder, propiedad de medios de producción, y concentración de capital en la industria tech.
          </p>

          <div class="flex flex-wrap items-center gap-4">
            <a
              href="#posts"
              class="inline-flex items-center gap-2 px-7 py-3.5 bg-gradient-to-r from-brand-600 to-fuchsia-600 text-white font-semibold rounded-xl shadow-lg shadow-brand-500/25 hover:shadow-brand-500/40 hover:scale-[1.02] transition-all duration-300"
            >
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
              </svg>
              Leer artículos
            </a>
            <a
              href="/about"
              class="inline-flex items-center gap-2 px-7 py-3.5 text-[rgb(var(--color-text-secondary))] font-semibold rounded-xl border border-[rgb(var(--color-border))] hover:border-[rgb(var(--color-brand)/0.5)] hover:text-[rgb(var(--color-brand))] hover:bg-[rgb(var(--color-brand)/0.05)] transition-all duration-300"
            >
              Sobre mí
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Posts Section -->
    <section id="posts">
      {posts.length > 0 ? (
        <div>
          <div class="flex items-center gap-3 mb-10" data-animate>
            <div class="h-px flex-1 bg-gradient-to-r from-[rgb(var(--color-brand)/0.3)] to-transparent"></div>
            <h2 class="text-lg font-semibold text-[rgb(var(--color-text))] tracking-tight">Últimos artículos</h2>
            <div class="h-px flex-1 bg-gradient-to-l from-[rgb(var(--color-brand)/0.3)] to-transparent"></div>
          </div>

          <div class="grid gap-5">
            {posts.map((post, index) => (
              <article
                class="group relative"
                data-animate
                style={`animation-delay: ${index * 0.1}s`}
              >
                <a href={`/${post.id}`} class="block">
                  <div class="glass rounded-2xl p-6 sm:p-8 hover-lift">
                    <!-- Top row: date + tags -->
                    <div class="flex flex-wrap items-center gap-3 mb-4">
                      <time
                        datetime={post.data.pubDate.toISOString()}
                        class="text-sm font-medium text-[rgb(var(--color-text-muted))]"
                      >
                        {post.data.pubDate.toLocaleDateString('es-ES', {
                          year: 'numeric',
                          month: 'long',
                          day: 'numeric',
                        })}
                      </time>
                      <div class="flex flex-wrap gap-2">
                        {post.data.tags.slice(0, 3).map((tag) => (
                          <span class="tag-chip">
                            {tag}
                          </span>
                        ))}
                      </div>
                    </div>

                    <!-- Title -->
                    <h3 class="text-xl sm:text-2xl font-bold text-[rgb(var(--color-text))] group-hover:text-[rgb(var(--color-brand))] transition-colors duration-300 mb-3 leading-tight">
                      {post.data.title}
                    </h3>

                    <!-- Description -->
                    <p class="text-[rgb(var(--color-text-secondary))] leading-relaxed line-clamp-2 mb-5">
                      {post.data.description}
                    </p>

                    <!-- Bottom row -->
                    <div class="flex items-center justify-between">
                      <div class="flex items-center gap-2 text-sm text-[rgb(var(--color-text-muted))]">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
                        </svg>
                        <span>Fuente: {post.data.source}</span>
                      </div>
                      <span class="text-sm font-medium text-[rgb(var(--color-brand))] opacity-0 group-hover:opacity-100 transition-all duration-300 flex items-center gap-1 translate-x-2 group-hover:translate-x-0">
                        Leer más
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                        </svg>
                      </span>
                    </div>
                  </div>
                </a>
              </article>
            ))}
          </div>
        </div>
      ) : (
        <div class="glass rounded-2xl p-12 text-center" data-animate>
          <div class="w-16 h-16 mx-auto mb-6 rounded-2xl bg-gradient-to-br from-brand-100 to-fuchsia-100 dark:from-brand-900/50 dark:to-fuchsia-900/50 flex items-center justify-center">
            <svg class="w-8 h-8 text-brand-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-[rgb(var(--color-text))] mb-2">Próximamente</h3>
          <p class="text-[rgb(var(--color-text-muted))] max-w-md mx-auto">
            Los artículos aparecerán aquí cuando se publiquen. El primer contenido llegará pronto.
          </p>
        </div>
      )}
    </section>
  </div>
</BaseLayout>
