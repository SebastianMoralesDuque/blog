---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title="Inicio">
  <div class="max-w-4xl mx-auto px-4 py-12 md:py-16">
    <!-- Hero Section -->
    <section class="mb-12 md:mb-16">
      <h1 class="text-4xl md:text-5xl font-extrabold tracking-tight text-gray-900 mb-4">
        Crítica Tecnológica
      </h1>
      <p class="text-xl text-gray-600 max-w-2xl leading-relaxed">
        Análisis diario de tecnología desde la perspectiva del materialismo histórico.
        Relaciones de poder, propiedad de medios de producción, y concentración de capital en la industria tech.
      </p>
    </section>

    <!-- Posts Grid -->
    {posts.length > 0 ? (
      <section>
        <h2 class="text-2xl font-bold text-gray-900 mb-6">Últimos artículos</h2>
        <div class="space-y-8">
          {posts.map((post) => (
            <article class="group">
              <a href={`/${post.id}`} class="block">
                <div class="flex flex-col sm:flex-row sm:items-center gap-2 sm:gap-4 mb-2">
                  <time
                    datetime={post.data.pubDate.toISOString()}
                    class="text-sm text-gray-500"
                  >
                    {post.data.pubDate.toLocaleDateString('es-ES', {
                      year: 'numeric',
                      month: 'long',
                      day: 'numeric',
                    })}
                  </time>
                  <div class="flex flex-wrap gap-2">
                    {post.data.tags.slice(0, 3).map((tag) => (
                      <span class="inline-block px-2 py-0.5 text-xs font-medium text-brand-700 bg-brand-100 rounded-full">
                        {tag}
                      </span>
                    ))}
                  </div>
                </div>

                <h3 class="text-xl md:text-2xl font-bold text-gray-900 group-hover:text-brand-600 transition-colors mb-2">
                  {post.data.title}
                </h3>

                <p class="text-gray-600 leading-relaxed line-clamp-2">
                  {post.data.description}
                </p>

                <div class="mt-3 text-sm text-gray-500">
                  Fuente: {post.data.source}
                </div>
              </a>
            </article>
          ))}
        </div>
      </section>
    ) : (
      <section class="text-center py-16">
        <div class="text-gray-400 mb-4">
          <svg class="w-12 h-12 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
          </svg>
        </div>
        <h3 class="text-lg font-medium text-gray-900 mb-2">Próximamente</h3>
        <p class="text-gray-500">Los artículos aparecerán aquí cuando se publiquen.</p>
      </section>
    )}
  </div>
</BaseLayout>
