---
const currentYear = new Date().getFullYear();

const socialLinks = [
  {
    href: 'https://linkedin.com/in/sebastianmorales',
    label: 'LinkedIn',
    icon: 'M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z',
  },
  {
    href: 'https://github.com/sebastianmorales',
    label: 'GitHub',
    icon: 'M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12',
  },
  {
    href: 'mailto:dev@sebastianmorales.sbs',
    label: 'Email',
    icon: 'M1.5 8.67v8.58a3 3 0 003 3h15a3 3 0 003-3V8.67l-8.928 5.493a3 3 0 01-3.144 0L1.5 8.67z M22.5 6.908V6.75a3 3 0 00-3-3h-15a3 3 0 00-3 3v.158l9.714 5.978a1.5 1.5 0 001.572 0L22.5 6.908z',
  },
];
---

<footer class="relative mt-auto">
  <!-- Top gradient line -->
  <div class="h-px bg-gradient-to-r from-transparent via-[rgb(var(--color-brand)/0.3)] to-transparent"></div>

  <div class="glass border-t-0 rounded-none">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 py-12">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Brand -->
        <div class="md:col-span-1">
          <a href="/" class="flex items-center gap-3 mb-4 group">
            <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-brand-500 to-fuchsia-500 flex items-center justify-center text-white font-bold text-xs shadow-lg shadow-brand-500/20 group-hover:shadow-brand-500/40 transition-all duration-300">
              CT
            </div>
            <span class="font-bold text-[rgb(var(--color-text))] tracking-tight">Crítica Tecnológica</span>
          </a>
          <p class="text-sm text-[rgb(var(--color-text-secondary))] leading-relaxed max-w-xs">
            Análisis diario de tecnología desde la perspectiva del materialismo histórico.
          </p>
        </div>

        <!-- Navigation -->
        <div class="md:col-span-1">
          <h3 class="text-sm font-semibold text-[rgb(var(--color-text))] mb-4 uppercase tracking-wider">Navegación</h3>
          <ul class="space-y-2.5">
            <li>
              <a href="/" class="text-sm text-[rgb(var(--color-text-secondary))] hover:text-[rgb(var(--color-brand))] transition-colors duration-200 animated-underline">
                Inicio
              </a>
            </li>
            <li>
              <a href="/about" class="text-sm text-[rgb(var(--color-text-secondary))] hover:text-[rgb(var(--color-brand))] transition-colors duration-200 animated-underline">
                Sobre mí
              </a>
            </li>
            <li>
              <a href="/rss.xml" class="text-sm text-[rgb(var(--color-text-secondary))] hover:text-orange-500 transition-colors duration-200 animated-underline">
                RSS Feed
              </a>
            </li>
          </ul>
        </div>

        <!-- Social -->
        <div class="md:col-span-1">
          <h3 class="text-sm font-semibold text-[rgb(var(--color-text))] mb-4 uppercase tracking-wider">Conecta</h3>
          <div class="flex items-center gap-2">
            {socialLinks.map((link) => (
              <a
                href={link.href}
                target={link.href.startsWith('mailto') ? undefined : '_blank'}
                rel={link.href.startsWith('mailto') ? undefined : 'noopener noreferrer'}
                class="p-2.5 text-[rgb(var(--color-text-muted))] hover:text-[rgb(var(--color-brand))] hover:bg-[rgb(var(--color-brand)/0.05)] rounded-xl transition-all duration-200"
                aria-label={link.label}
              >
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d={link.icon} />
                </svg>
              </a>
            ))}
          </div>
        </div>
      </div>

      <!-- Bottom bar -->
      <div class="mt-10 pt-6 border-t border-[rgb(var(--color-border-subtle))]">
        <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
          <p class="text-xs text-[rgb(var(--color-text-muted))]">
            © {currentYear} Sebastian Morales. Todos los derechos reservados.
          </p>
          <p class="text-xs text-[rgb(var(--color-text-muted))]">
            Hecho con <span class="text-brand-500">♥</span> y materialismo histórico
          </p>
        </div>
      </div>
    </div>
  </div>
</footer>
