---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  image?: string;
}

const {
  title,
  description = 'Análisis crítico de tecnología desde el materialismo histórico',
  image = '/og-default.png',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const umamiWebsiteId = import.meta.env.UMAMI_WEBSITE_ID;
const umamiScriptUrl = import.meta.env.UMAMI_SCRIPT_URL || 'https://analytics.sebastianmorales.sbs/script.js';
const isDev = import.meta.env.DEV;
---

<!DOCTYPE html>
<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="author" content="Sebastian Morales" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Playfair+Display:wght@600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />

    <!-- Canonical URL -->
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, Astro.site)} />
    <meta property="og:locale" content="es_ES" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(image, Astro.site)} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- JSON-LD Blog Schema -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Blog",
      "name": "Crítica Tecnológica",
      "description": description,
      "url": Astro.site?.href,
      "author": {
        "@type": "Person",
        "name": "Sebastian Morales",
        "url": "https://sebastianmorales.sbs"
      }
    })} />

    <!-- Umami Analytics -->
    {!isDev && umamiWebsiteId && (
      <script
        defer
        data-website-id={umamiWebsiteId}
        src={umamiScriptUrl}
        data-astro-rerun
      />
    )}

    <title>{title} | Crítica Tecnológica</title>
  </head>
  <body class="min-h-screen flex flex-col bg-surface-50 antialiased">
    <!-- Background gradient -->
    <div class="fixed inset-0 -z-10">
      <div class="absolute inset-0 bg-gradient-to-br from-brand-50/50 via-surface-50 to-fuchsia-50/30"></div>
      <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-brand-200/20 rounded-full blur-3xl -translate-y-1/2 translate-x-1/3"></div>
      <div class="absolute bottom-0 left-0 w-[500px] h-[500px] bg-fuchsia-200/15 rounded-full blur-3xl translate-y-1/3 -translate-x-1/4"></div>
    </div>

    <Header />
    <main class="flex-1 relative">
      <slot />
    </main>
    <Footer />
  </body>
</html>
