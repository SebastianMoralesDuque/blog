---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  image?: string;
}

const {
  title,
  description = 'Análisis crítico de tecnología desde el materialismo histórico',
  image = '/og-default.png',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const umamiWebsiteId = import.meta.env.UMAMI_WEBSITE_ID;
const umamiScriptUrl = import.meta.env.UMAMI_SCRIPT_URL || 'https://analytics.sebastianmorales.sbs/script.js';
const isDev = import.meta.env.DEV;
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="author" content="Sebastian Morales" />

    <!-- Canonical URL -->
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, Astro.site)} />
    <meta property="og:locale" content="es_ES" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(image, Astro.site)} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- JSON-LD Blog Schema -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Blog",
      "name": "Crítica Tecnológica",
      "description": description,
      "url": Astro.site?.href,
      "author": {
        "@type": "Person",
        "name": "Sebastian Morales",
        "url": "https://sebastianmorales.sbs"
      }
    })} />

    <!-- Umami Analytics -->
    {!isDev && umamiWebsiteId && (
      <script
        defer
        data-website-id={umamiWebsiteId}
        src={umamiScriptUrl}
        data-astro-rerun
      />
    )}

    <title>{title} | Crítica Tecnológica</title>
  </head>
  <body class="min-h-screen flex flex-col">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
