# Blog Generator Environment Variables
# Copy this file to .env and fill in the values

# Ollama Configuration
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=minimax-m3:cloud

# Site Configuration
SITE_URL=https://blog.sebastianmorales.sbs

# File Browser Configuration (optional - for image hosting)
FILEBROWSER_URL=https://files.sebastianmorales.sbs
FILEBROWSER_USER=sebas
FILEBROWSER_PASS=

# Pollinations.ai (no API key needed - free service)
# No configuration needed - images are served directly from CDN

# Logging
BLOG_LOG_PATH=/home/ubuntu/projects/blog/blog-generation.log
